{
  "realm": "domaine-flotte",
  "displayName": "Gestion de Flotte",
  "enabled": true,
  "sslRequired": "external",
  "accessTokenLifespan": 900,
  "roles": {
    "realm": [
      { "name": "administrateur", "description": "Acces total" },
      { "name": "responsable", "description": "Supervision flotte" },
      { "name": "technicien", "description": "Gestion maintenance" },
      { "name": "utilisateur", "description": "Conducteur standard" }
    ]
  },
  "clients": [
    {
      "clientId": "flotte-interface",
      "publicClient": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"]
    },
    {
      "clientId": "flotte-passerelle",
      "publicClient": false,
      "serviceAccountsEnabled": true
    }
  ]
}
